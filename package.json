  "type": "module",
  "scripts": {
    "dev": "bun dev:web",
    "build": "bun build:web",
    "start": "bun start:web",
    "db": "bun -F=@repo/db run db",
    "dev:docs": "bun -F=@repo/reliverse-docs dev",
    "dev:web": "bun -F=@repo/reliverse-web dev",
    "dev:api": "bun -F=@repo/reliverse-api dev",
    "dev:cli": "bun -F=@repo/reliverse-cli dev",
    "latest": "bun dler update && bun install",
    "fresh": "bun scripts/clean.ts && bun install",
    "start:web": "bun -F=@repo/reliverse-web start",
    "build:web": "bun -F=@repo/reliverse-web build",
    "smoke:web": "bun -F=@repo/reliverse-web run smoke",
    "reliverse:rse": "bun cli/src/cli.ts",
    "reliverse:pub": "bun run build && bun dler publish --skip-tip-2fa",
    "reliverse:build": "bun clean && bun typecheck && bun dler build",
    "reliverse:clean": "bun dler clean --presets build --force",
    "reliverse:typecheck": "bun dler tsc --copy-logs",
    "reliverse:check": "bun format && bun typecheck",
    "reliverse:format": "bun biome check --write --unsafe",
    "reliverse:latest": "bun dler update && bun install && bun check",
    "reliverse:escaper": "bun rse escape --input 'packages/rules/src/rules' --map 'md:.rules'",
    "reliverse:scripts": "bun scripts/src/cli.ts",
    "build:turbo": "bun check && turbo run build",
    "dev:turbo": "turbo run dev",
    "turbo:build": "turbo run build",
    "turbo:dev": "turbo run dev --parallel",
    "turbo:dev:web": "turbo run dev -F=@repo/web",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --type-aware --type-check --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "turbo:quality": "turbo run quality",
    "deps": "bunx taze@latest -Ilwr",
    "deps:major": "bunx taze@latest major -Ilwr",
    "ui": "bun -F=@repo/ui run ui",
    "ui:web": "bun -F=@repo/web run ui",
    "auth:secret": "bunx @better-auth/cli@latest secret",
    "auth:generate": "bun -F=@repo/db run auth:generate",
    "skills": "bunx skills@latest",
    "check": "bun format && bun lint",
    "dler:typecheck": "bun dler tsc",
    "test": "turbo run test",
    "format:fix": "turbo run format:fix",
    "lint:ws": "bunx sherif@latest",
    "lint:ws:fix": "bunx sherif@latest --fix",
    "ck": "turbo run typecheck test format lint && bun run lint:ws",
    "ck:fix": "turbo run format:fix lint:fix && bun run lint:ws:fix",
    "pr": "bun run ck:fix && bun run ck",
    "dev:all": "bun run -F='*' dev",
    "build:all": "bun run -F='*' build",
    "prepare:env": "bun scripts/prepare.ts"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@tanstack/eslint-plugin-router": "^1.161.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-turbo": "^2.8.11",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.15.0",
    "turbo": "^2.8.8"
