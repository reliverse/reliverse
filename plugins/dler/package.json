{
  "name": "@reliverse/dler-rse-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./build-runtime": "./src/impl/build/index.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts ./src/cmds/dler/build/cmd.ts ./src/cmds/dler/pub/cmd.ts --outdir ./dist --target bun",
    "check": "bun --eval \"import('./src/index.ts').then(() => console.log('ok'))\"",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@reliverse/rempts": "workspace:*"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}
