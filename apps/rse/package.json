{
  "name": "@reliverse/rse",
  "version": "2.0.8",
  "private": false,
  "author": "reliverse",
  "bin": {
    "rse": "./src/cli.ts"
  },
  "type": "module",
  "types": "./src/cli.ts",
  "exports": {
    ".": {
      "types": "./src/cli.ts",
      "import": "./src/cli.ts"
    }
  },
  "sideEffects": [
    "./src/cli.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun ./src/cli.ts",
    "check": "bun ./src/cli.ts --help"
  },
  "dependencies": {
    "@reliverse/rempts": "workspace:*"
  },
  "devDependencies": {
    "@reliverse/dler-rse-plugin": "workspace:*",
    "@reliverse/os-rse-plugin": "workspace:*",
    "@reliverse/pm-rse-plugin": "workspace:*",
    "@reliverse/relpack-rse-plugin": "workspace:*",
    "@reliverse/rempts-rse-plugin": "workspace:*",
    "@reliverse/rspace-rse-plugin": "workspace:*",
    "@reliverse/toolkit-rse-plugin": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}
