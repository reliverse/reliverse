{
  "name": "@repo/reliverse-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "PORT=${PORT:-3001} bun src/index.ts",
    "dev": "PORT=${PORT:-3001} bun --hot src/index.ts",
    "build": "tsdown",
    "typecheck": "tsgo -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "start:dist": "bun run dist/index.js"
  },
  "dependencies": {
    "@ai-sdk/devtools": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@elysiajs/cors": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@repo/auth": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/env": "workspace:*",
    "@repo/server": "workspace:*",
    "@repo/ui": "workspace:*",
    "ai": "catalog:",
    "better-auth": "catalog:",
    "elysia": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:",
    "tsdown": "catalog:"
  }
}
