{
  "name": "@repo/convex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#convex/*": "./src/*"
  },
  "exports": {
    "./_generated/api": {
      "types": "./src/_generated/api.d.ts",
      "default": "./src/_generated/api.js"
    },
    "./_generated/server": {
      "types": "./src/_generated/server.d.ts",
      "default": "./src/_generated/server.js"
    },
    "./_generated/dataModel": {
      "types": "./src/_generated/dataModel.d.ts"
    }
  },
  "scripts": {
    "build": "tsgo",
    "dev": "convex dev",
    "typecheck": "tsgo --noEmit --emitDeclarationOnly false",
    "test": "echo 'NO TEST SUITE CONFIGURED'",
    "init": "convex dev --until-success"
  },
  "dependencies": {
    "@repo/env": "workspace:*",
    "arktype": "catalog:",
    "convex": "catalog:",
    "neverthrow": "catalog:",
    "zod": "catalog:",
    "zodvex": "catalog:"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}
